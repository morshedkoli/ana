# ============================================================
# Required
# ============================================================

# Long random string used to sign session cookies (HMAC-SHA-256).
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Rotating this signs out every existing user.
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ============================================================
# Optional — most credentials live in /studio and /library configure modals.
# These environment variables are only read as fallbacks.
# ============================================================

# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# Set to production when deployed
NODE_ENV=development
